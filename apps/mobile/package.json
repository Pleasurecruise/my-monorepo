		"dev:ios": "expo start --ios",
		"build:android": "expo run:android",
		"build:ios": "expo run:ios",
		"check-types": "vp lint --type-aware --type-check",
		"lint": "vp lint",
		"lint:fix": "vp lint --fix",
		"format": "vp fmt",
		"format:check": "vp fmt --check",
		"test": "vp test --run",
		"test:coverage": "vp test --run --coverage",
		"android": "expo run:android",
		"ios": "expo run:ios"
	},
	"dependencies": {
		"@better-auth/expo": "latest",
		"@expo/log-box": "latest",
		"@expo/metro-runtime": "latest",
		"@my-monorepo/i18n": "workspace:*",
		"@my-monorepo/ui-native": "workspace:*",
		"@my-monorepo/utils": "workspace:*",
		"@react-navigation/native": "latest",
		"@tanstack/react-query": "latest",
		"@trpc/client": "latest",
		"@trpc/tanstack-react-query": "latest",
		"better-auth": "latest",
		"expo": "latest",
		"expo-constants": "latest",
		"expo-linking": "latest",
		"expo-localization": "latest",
		"expo-network": "latest",
		"expo-router": "latest",
		"expo-secure-store": "latest",
		"expo-web-browser": "latest",
		"nativewind": "4.2.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-native": "0.83.4",
		"react-native-css": "latest",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "5.7.0",
		"react-native-screens": "4.24.0"
	},
	"devDependencies": {
		"@my-monorepo/api": "workspace:*",
		"tailwindcss": "3.4.19",
		"tailwindcss-animate": "latest"
	}
