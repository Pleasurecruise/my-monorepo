{
	"name": "@my-monorepo/api",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"exports": {
		"./routers": {
			"types": "./dist/trpc/routers/index.d.ts",
			"default": "./dist/trpc/routers/index.js"
		}
	},
	"scripts": {
		"dev": "bun --watch --env-file ../../.env src/index.ts",
		"build": "tsc --project tsconfig.json --outDir dist && tsc-alias -p tsconfig.json --outDir dist",
		"start": "bun dist/index.js",
		"check-types": "vp lint --type-aware --type-check",
		"lint": "vp lint",
		"lint:fix": "vp lint --fix",
		"format": "vp fmt",
		"format:check": "vp fmt --check",
		"test": "vp test --run",
		"test:coverage": "vp test --run --coverage"
	},
	"dependencies": {
		"@hono/node-server": "1.19.13",
		"@hono/trpc-server": "0.4.2",
		"@my-monorepo/ai": "workspace:*",
		"@my-monorepo/auth": "workspace:*",
		"@my-monorepo/env": "workspace:*",
		"@my-monorepo/logger": "workspace:*",
		"@my-monorepo/utils": "workspace:*",
		"@trpc/server": "11.16.0",
		"hono": "4.12.12"
	},
	"devDependencies": {
		"@my-monorepo/tsconfig": "workspace:*",
		"tsc-alias": "1.8.16"
	},
	"engines": {
		"bun": "1.3.10"
	}
}
