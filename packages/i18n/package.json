{
	"name": "@my-monorepo/i18n",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./core": "./src/core.ts",
		"./react": "./src/react.ts",
		"./locales/*": "./src/locales/*.ts"
	},
	"scripts": {
