{
	"name": "@my-monorepo/ui-native",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"exports": {
		"./components/ui/*": "./src/components/ui/*.tsx",
		"./lib/*": "./src/lib/*.ts",
		"./styles/*": "./src/styles/*.css"
	},
	"scripts": {
		"lint": "vp lint",
		"lint:fix": "vp lint --fix",
		"format": "vp fmt",
		"format:check": "vp fmt --check",
		"check-types": "vp lint --type-aware --type-check"
	},
	"dependencies": {
		"@rn-primitives/slot": "latest",
		"class-variance-authority": "latest",
		"clsx": "latest",
		"tailwind-merge": "latest"
	},
	"devDependencies": {
		"@my-monorepo/tsconfig": "workspace:*",
		"@react-navigation/native": "latest",
		"nativewind": "4.2.3",
		"react": "19.2.4",
		"react-native": "0.83.2",
		"tailwindcss": "3.4.19"
	}
}
