{
	"name": "my-monorepo",
	"private": true,
	"scripts": {
		"dev:api": "turbo dev --filter=@my-monorepo/api",
		"dev:web": "turbo dev --filter=@my-monorepo/web",
		"dev:tauri": "turbo dev --filter=@my-monorepo/tauri",
		"dev:expo": "turbo dev --filter=@my-monorepo/mobile",
		"build:ui": "turbo build --filter=@my-monorepo/ui",
		"build:web": "turbo build --filter=@my-monorepo/web",
		"build:tauri": "turbo build --filter=@my-monorepo/tauri",
		"lint": "turbo lint && manypkg check",
		"lint:fix": "turbo lint:fix",
		"format": "turbo format",
		"format:check": "turbo format -- --check",
		"check-types": "turbo check-types",
		"test": "turbo test",
		"test:coverage": "turbo test:coverage",
		"precommit": "pnpm run format:check && pnpm run lint && pnpm run check-types && pnpm run test",
		"precommit:fix": "pnpm run format && pnpm run lint:fix"
	},
	"devDependencies": {
		"@manypkg/cli": "latest",
		"@tailwindcss/vite": "latest",
		"@types/node": "latest",
		"@types/react": "latest",
		"@types/react-dom": "latest",
		"@typescript/native-preview": "latest",
		"@vitejs/plugin-react": "latest",
		"@vitest/coverage-v8": "latest",
		"react": "latest",
		"react-dom": "latest",
		"simple-git-hooks": "latest",
		"turbo": "latest",
		"typescript": "latest",
		"vite-plus": "latest"
	},
	"packageManager": "pnpm@10.32.1",
	"simple-git-hooks": {
		"pre-commit": "pnpm run precommit"
	},
	"pnpm": {
		"overrides": {
			"inflight": "1.0.6",
			"lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
			"hono@<4.11.7": ">=4.11.7",
			"hono@<4.11.10": ">=4.11.10",
			"minimatch@<3.1.3": ">=3.1.3",
			"minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
			"rollup@>=4.0.0 <4.59.0": ">=4.59.0"
		}
	}
}
